// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../lib/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// User & Authentication
// =============================================================================

model User {
  id            String    @id @default(cuid())
  
  // NextAuth.js Integration
  email         String    @unique
  emailVerified DateTime?
  password      String?   // Hashed password for credentials provider
  name          String?   // Full name (can be split into firstName/lastName)
  firstName     String
  lastName      String
  phone         String?
  image         String?   // Avatar URL
  
  role          UserRole  @default(MEMBER)
  status        UserStatus @default(ACTIVE)
  
  // Multi-tenancy: SME (Organization) Info
  businessId    String    // SME ID
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  // User Preferences
  timezone      String    @default("Europe/London")
  avatar        String?
  notificationPreferences Json? // Store notification settings
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  
  // NextAuth.js Relations
  accounts      Account[]
  sessions      Session[]
  
  // Business Relations
  invoices      Invoice[]
  contacts      Contact[]
  tasks         Task[]
  notes         Note[]
  expenses      Expense[]
  tickets       Ticket[]
  journalEntries JournalEntry[]
  emailLogs     EmailLog[]
  forms         Form[]
  appointments  Appointment[]
  ticketComments TicketComment[]
  aiNotes        AINote[]
  stockMovements StockMovement[]
  notifications  Notification[]

  
  @@index([email])
  @@index([businessId])
}

// NextAuth.js Account Model (for OAuth providers)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// NextAuth.js Session Model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// NextAuth.js Verification Token Model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  SUPER_ADMIN // Platform admin - manages all SMEs and users
  OWNER       // SME Owner - full access to their business
  ADMIN       // Admin - can manage users and settings within SME
  MANAGER     // Manager - can see team data (Tier 3 feature)
  MEMBER      // Basic member - sees own data only
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// =============================================================================
// Business
// =============================================================================

model Business {
  id              String   @id @default(cuid())
  
  name            String
  industry        String
  size            String
  address         String?
  city            String?
  postcode        String?
  country         String   @default("UK")
  
  // Subscription & Billing
  subscriptionId  String?  @unique
  subscription    Subscription?
  
  // Seat Management (for per-seat billing)
  seatCount       Int      @default(1)
  maxSeats        Int      @default(10) // Based on tier
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  users           User[]
  invoices        Invoice[]
  contacts        Contact[]
  tasks           Task[]
  notes           Note[]
  expenses        Expense[]
  inventory       InventoryItem[]
  employees       Employee[]
  suppliers       Supplier[]
  campaigns       Campaign[]
  tickets         Ticket[]
  ledgerAccounts  LedgerAccount[]
  journalEntries  JournalEntry[]
  emailLogs       EmailLog[]
  forms           Form[]
  appointments    Appointment[]
  aiNotes         AINote[]
  stockMovements  StockMovement[]

  @@index([name])
}

// =============================================================================
// Subscription & Billing
// =============================================================================

model Subscription {
  id                String   @id @default(cuid())
  businessId        String   @unique
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  stripeCustomerId      String?  @unique
  stripeSubscriptionId  String?  @unique
  stripePriceId         String?
  
  status            SubscriptionStatus @default(TRIAL)
  plan              String   @default("all-in-one")
  amount            Int      @default(1999) // in pence
  currency          String   @default("gbp")
  
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)
  trialEnd           DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

// =============================================================================
// Invoicing Module
// =============================================================================

model Invoice {
  id            String   @id @default(cuid())
  number        String   @unique
  
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  clientName    String
  clientEmail   String?
  clientAddress String?
  
  amount        Float
  currency      String   @default("GBP")
  status        InvoiceStatus @default(DRAFT)
  
  items         Json     // Array of invoice items
  notes         String?
  
  dueDate       DateTime
  paidAt        DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Ledger Integration
  journalEntryId String?   @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  
  @@index([businessId])
  @@index([userId])
  @@index([status])
  @@index([number])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PENDING
  PAID
  OVERDUE
  CANCELED
}

// =============================================================================
// CRM Module
// =============================================================================

model Contact {
  id            String   @id @default(cuid())
  
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  name          String
  email         String
  phone         String?
  company       String?
  position      String?
  address       String?
  
  clientType    String        @default("business")
  pipelineStage String        @default("new")
  revenue       Float         @default(0)
  lastContact   DateTime?
  
  status        ContactStatus @default(LEAD)
  source        String?
  tags          String[]
  notes         String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([businessId])
  @@index([userId])
  @@index([email])
  @@index([status])
}

enum ContactStatus {
  LEAD
  ACTIVE
  INACTIVE
  CUSTOMER
}


// =============================================================================
// AI Notes Module
// =============================================================================

model Note {
  id            String   @id @default(cuid())
  
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  title         String
  content       String   @db.Text
  tags          String[]
  
  isAiGenerated Boolean  @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([businessId])
  @@index([userId])
}

// =============================================================================
// Expense Tracker Module
// =============================================================================

model Expense {
  id            String   @id @default(cuid())
  
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  description   String
  amount        Float
  currency      String   @default("GBP")
  category      String
  
  receipt       String?  // URL to receipt image
  date          DateTime
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Ledger Integration
  journalEntryId String?   @unique
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  
  @@index([businessId])
  @@index([userId])
  @@index([category])
  @@index([date])
}

// =============================================================================
// Inventory Module
// =============================================================================

model InventoryItem {
  id            String   @id @default(cuid())
  
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  name          String
  sku           String   @unique
  barcode       String?
  description   String?  @db.Text
  
  quantity      Int      @default(0)
  minQuantity   Int      @default(0)
  maxQuantity   Int      @default(100)
  reorderPoint  Int      @default(10)
  
  price         Float    @default(0) // unitPrice in UI
  cost          Float    @default(0)
  
  category      String?
  location      String?
  unit          String   @default("pcs")
  
  weight        Float?
  dimensions    String?
  expiryDate    DateTime?
  image         String?
  tags          String[]
  
  status        InventoryStatus @default(IN_STOCK)
  
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  movements     StockMovement[]

  @@index([businessId])
  @@index([sku])
  @@index([status])
}

model StockMovement {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  itemId        String
  item          InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  type          String   // 'IN', 'OUT', 'ADJUSTMENT', 'TRANSFER'
  quantity      Int
  date          DateTime @default(now())
  reason        String?
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  
  createdAt     DateTime @default(now())
  
  @@index([itemId])
  @@index([businessId])
}

enum InventoryStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  OVERSTOCKED
}

// =============================================================================
// HR Records Module
// =============================================================================

model Employee {
  id            String   @id @default(cuid())
  
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  firstName     String
  lastName      String
  email         String
  phone         String?
  
  position      String
  department    String
  
  startDate     DateTime
  endDate       DateTime?
  
  salary        Float?
  status        EmployeeStatus @default(ACTIVE)
  
  address       String?
  emergencyContact String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([businessId])
  @@index([email])
  @@index([status])
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

// =============================================================================
// Supplier Tracker Module
// =============================================================================

model Supplier {
  id            String   @id @default(cuid())
  
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  name          String
  contactName   String?
  email         String
  phone         String?
  address       String?
  
  category      String?
  rating        Int?     @default(0)
  
  status        SupplierStatus @default(ACTIVE)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  inventoryItems InventoryItem[]
  
  @@index([businessId])
  @@index([email])
  @@index([status])
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

// =============================================================================
// Campaigns Module
// =============================================================================

model Campaign {
  id            String         @id @default(cuid())

  businessId    String
  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name          String
  subject       String?
  content       String?        @db.Text
  type          CampaignType   @default(PROMOTIONAL)
  audience      String         @default("All Subscribers")

  status        CampaignStatus @default(DRAFT)

  sentCount     Int            @default(0)
  openedCount   Int            @default(0)
  clickedCount  Int            @default(0)
  bouncedCount  Int            @default(0)
  unsubscribed  Int            @default(0)
  revenue       Float          @default(0)
  cost          Float          @default(0)

  scheduledAt   DateTime?
  sentAt        DateTime?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([businessId])
  @@index([status])
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  COMPLETED
}

enum CampaignType {
  PROMOTIONAL
  NEWSLETTER
  TRANSACTIONAL
  ANNOUNCEMENT
}

// =============================================================================
// Helpdesk Module
// =============================================================================

model Ticket {
  id            String   @id @default(cuid())
  
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  
  subject       String
  description   String   @db.Text
  category      String   @default("Support")
  
  status        TicketStatus @default(OPEN)
  priority      TicketPriority @default(MEDIUM)
  
  customerName  String
  customerEmail String
  
  assignedTo    String?
  
  resolvedAt    DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  comments      TicketComment[]
  
  @@index([businessId])
  @@index([userId])
  @@index([status])
  @@index([priority])
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  
  authorName  String
  authorRole  String   // 'customer' or 'agent'
  content     String   @db.Text
  
  createdAt   DateTime @default(now())
  
  @@index([ticketId])
}

enum TicketStatus {
  OPEN
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// =============================================================================
// Appointments/Booking Module
// =============================================================================

model Appointment {
  id            String   @id @default(cuid())
  
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  title         String   // Service name
  description   String?  // Notes
  
  clientName    String
  clientEmail   String
  clientPhone   String?
  
  startTime     DateTime
  endTime       DateTime
  
  status        AppointmentStatus @default(PENDING)
  type          AppointmentType   @default(VIDEO)
  location      String?           // For in-person or meeting link
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([businessId])
  @@index([userId])
  @@index([status])
  @@index([startTime])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum AppointmentType {
  VIDEO
  PHONE
  IN_PERSON
}

// =============================================================================
// Compliance Reminders Module
// =============================================================================

model ComplianceItem {
  id            String   @id @default(cuid())
  
  businessId    String
  
  title         String
  description   String?
  
  dueDate       DateTime
  completedAt   DateTime?
  status        ComplianceStatus @default(PENDING)
  category      String?
  
  reminderSent  Boolean  @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([businessId])
  @@index([status])
  @@index([dueDate])
}

enum ComplianceStatus {
  PENDING
  COMPLETED
  OVERDUE
}

// =============================================================================
// Tasks Module
// =============================================================================

model Task {
  id            String    @id @default(cuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  userId        String?   // Creator
  user          User?     @relation(fields: [userId], references: [id])

  title         String
  description   String?   @db.Text
  
  status        TaskStatus   @default(TODO)
  priority      TaskPriority @default(MEDIUM)
  
  dueDate       DateTime?
  assignedTo    String?   // Name of assignee
  
  tags          String[]
  
  subtasks      SubTask[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([businessId])
  @@index([userId])
  @@index([status])
  @@index([priority])
}

model SubTask {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  title     String
  completed Boolean  @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// =============================================================================
// Audit Logs (Tier 2: 10-20 Users)
// =============================================================================

model AuditLog {
  id            String   @id @default(cuid())
  
  smeId         String   // Organization ID
  businessId    String   // For backward compatibility
  
  userId        String   // Who performed the action
  userEmail     String   // Denormalized for quick lookup
  
  action        String   // CREATE, UPDATE, DELETE, etc.
  resourceType  String   // Invoice, Contact, Task, etc.
  resourceId    String   // ID of the resource
  
  changes       Json?    // Before/after changes
  metadata      Json?    // Additional context
  
  ipAddress     String?
  userAgent     String?
  
  createdAt     DateTime @default(now())
  
  @@index([smeId])
  @@index([businessId])
  @@index([userId])
  @@index([resourceType])
  @@index([createdAt])
}

// =============================================================================
// Workspace Visibility (Tier 2: Shared vs Private)
// =============================================================================

model WorkspaceVisibility {
  id            String   @id @default(cuid())
  
  smeId         String
  businessId    String
  
  resourceType  String   // Invoice, Contact, Task, Note, etc.
  resourceId    String   // ID of the resource
  
  visibility    VisibilityType @default(PRIVATE)
  
  // If SHARED, which users can access (empty = all users in SME)
  sharedWithUserIds String[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([resourceType, resourceId])
  @@index([smeId])
  @@index([businessId])
  @@index([visibility])
}

enum VisibilityType {
  PRIVATE  // Only creator can see
  SHARED   // Shared with team (or specific users)
}

// =============================================================================
// Accounting & Bookkeeping (HMRC Compliant Double-Entry)
// =============================================================================

model LedgerAccount {
  id            String   @id @default(cuid())
  code          String   // e.g. "1200" for Accounts Receivable
  name          String   // e.g. "Accounts Receivable"
  description   String?
  
  type          AccountType
  category      String   // e.g. "Current Assets", "Operating Expenses"
  
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  isActive      Boolean  @default(true)
  isSystem      Boolean  @default(false) // If true, cannot be deleted (e.g., Accounts Payable)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  ledgerEntries LedgerEntry[]
  
  @@unique([businessId, code])
  @@index([businessId])
  @@index([type])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model JournalEntry {
  id            String   @id @default(cuid())
  date          DateTime @default(now())
  description   String
  reference     String?  // e.g. Invoice #, Receipt #
  
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  status        JournalStatus @default(POSTED)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  entries       LedgerEntry[]
  
  // Source tracking
  invoice       Invoice?
  expense       Expense?
  
  @@index([businessId])
  @@index([date])
  @@index([status])
}

enum JournalStatus {
  DRAFT
  PENDING
  POSTED
  VOID
}

model LedgerEntry {
  id            String   @id @default(cuid())
  
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  
  accountId     String
  account       LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  debit         Float    @default(0)
  credit        Float    @default(0)
  
  description   String?  // Line-item specific description
  
  createdAt     DateTime @default(now())
  
  @@index([journalEntryId])
  @@index([accountId])
}

// =============================================================================
// Email Log (SME → Client emails)
// =============================================================================

model EmailLog {
  id            String      @id @default(cuid())

  businessId    String
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  userId        String
  user          User        @relation(fields: [userId], references: [id])

  to            String
  cc            String?
  bcc           String?
  subject       String
  body          String      @db.Text
  attachments   Json?       // [{filename, objectKey, size, contentType}]

  status        EmailStatus @default(SENT)
  errorMessage  String?
  messageId     String?     // SMTP message ID

  createdAt     DateTime    @default(now())

  @@index([businessId])
  @@index([userId])
  @@index([createdAt])
}

enum EmailStatus {
  SENT
  FAILED
  QUEUED
}

// =============================================================================
// Forms Module
// =============================================================================

model Form {
  id          String      @id @default(cuid())

  businessId  String
  business    Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  userId      String
  user        User        @relation(fields: [userId], references: [id])

  name        String
  description String?
  category    String      @default("Contact")
  status      FormStatus  @default(DRAFT)
  webhookUrl  String?

  fieldList   Json        @default("[]") // FormField[]
  responses   Int         @default(0)
  responsesList FormResponse[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([businessId])
  @@index([userId])
  @@index([status])
}

model FormResponse {
  id        String   @id @default(cuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  data      Json     // The submitted fields
  
  createdAt DateTime @default(now())
  
  @@index([formId])
}

enum FormStatus {
  ACTIVE
  DRAFT
  CLOSED
}
// =============================================================================
// AI Notes Module
// =============================================================================

model AINote {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  
  title         String
  content       String
  type          String   // meeting, brainstorm, etc.
  date          DateTime @default(now())
  tags          String[]
  isPinned      Boolean  @default(false)
  isStarred     Boolean  @default(false)
  
  aiSummary     String?
  actionItems   String[]
  participants  String[]
  duration      String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
  @@index([userId])
}

// =============================================================================
// Notifications Module
// =============================================================================

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  businessId  String
  
  title       String
  message     String
  type        String   @default("info") // 'info', 'success', 'warning', 'error'
  status      String   @default("unread") // 'unread', 'read'
  
  link        String?  // Optional link to navigate to
  metadata    Json?    // Any additional data
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([businessId])
